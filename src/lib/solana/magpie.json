  "types": [
    {
      "name": "LendingPool",
      "docs": [
        "Global lending pool — single PDA that manages all lending operations.",
        "In BagBank, loan asset = wSOL; collateral = any SPL memecoin."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "lender",
            "docs": [
              "The lender's wallet address (pool operator)."
            ],
            "type": "pubkey"
          },
          {
            "name": "loan_token_vault",
            "docs": [
              "PDA token account holding the pool's wSOL for disbursing loans."
            ],
            "type": "pubkey"
          },
          {
            "name": "fee_wallet",
            "docs": [
              "Wallet where origination fees are collected."
            ],
            "type": "pubkey"
          },
          {
            "name": "total_loans_issued",
            "docs": [
              "Total number of loans issued (for tracking)."
            ],
            "type": "u64"
          },
          {
            "name": "total_liquidations",
            "docs": [
              "Total number of liquidations executed."
            ],
            "type": "u64"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump for verification."
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "Loan",
      "docs": [
        "Individual loan — one PDA per loan."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "loan_id",
            "docs": [
              "Unique loan identifier."
            ],
            "type": "u64"
          },
          {
            "name": "borrower",
            "docs": [
              "Borrower's wallet address."
            ],
            "type": "pubkey"
          },
          {
            "name": "collateral_mint",
            "docs": [
              "Mint address of the collateral token (e.g. BONK, WIF)."
            ],
            "type": "pubkey"
          },
          {
            "name": "collateral_vault",
            "docs": [
              "PDA token account holding the locked collateral."
            ],
            "type": "pubkey"
          },
          {
            "name": "collateral_amount",
            "docs": [
              "Amount of collateral tokens locked (raw, with decimals)."
            ],
            "type": "u64"
          },
          {
            "name": "loan_amount",
            "docs": [
              "Loan asset amount borrower actually receives (after fee). Denominated in the",
              "loan asset's smallest unit (for wSOL, lamports)."
            ],
            "type": "u64"
          },
          {
            "name": "original_loan_amount",
            "docs": [
